{
  "name": "wanzai",
  "private": true,
  "type": "module",
  "version": "2.0.0",
  "description": "焰境万载 — 数字文旅平台 Monorepo",
  "scripts": {
    "dev": "pnpm --filter @wanzai/frontend dev",
    "dev:backend": "pnpm --filter @wanzai/backend start:dev",
    "build": "pnpm --filter @wanzai/frontend build",
    "build:backend": "pnpm --filter @wanzai/backend build",
    "preview": "pnpm --filter @wanzai/frontend preview",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0"
  },
  "lint-staged": {
    "*.{ts,vue}": ["eslint --fix", "prettier --write"],
    "*.{json,md,css}": ["prettier --write"]
  }
}
