generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  phone     String?  @unique
  email     String?  @unique
  openId    String?  @unique
  nickname  String
  avatarUrl String?
  role      UserRole @default(TOURIST)
  createdAt DateTime @default(now())

  fireworks  FireworkRecipe[]
  coupons    UserCoupon[]
  comments      Comment[]
  commentLikes  CommentLike[]
  merchant      Merchant?
}

enum UserRole {
  TOURIST
  MERCHANT
  ADMIN
}

model Merchant {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  name       String
  nameEn     String?
  category   String   // dining, lodging, firework, specialty
  mapLng     Float
  mapLat     Float
  isVerified Boolean  @default(false)
  coverImage String?
  businessHours String?
  phone      String?
  description String?
  createdAt  DateTime @default(now())

  coupons    Coupon[]
}

model FireworkRecipe {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  config    Json     // IFireworkConfig
  shareSlug String   @unique
  viewCount Int      @default(0)
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
}

model Coupon {
  id         String   @id @default(uuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  title      String
  titleEn    String?
  discount   Float
  totalStock Int
  usedStock  Int      @default(0)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  userCoupons UserCoupon[]
}

model UserCoupon {
  id         String   @id @default(uuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  redeemCode String   @unique
  isRedeemed Boolean  @default(false)
  claimedAt  DateTime @default(now())
  redeemedAt DateTime?
}

model KnowledgeEntry {
  id        String   @id @default(uuid())
  category  String
  content   String
  contentEn String?
  keywords  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Doc {
  id         String   @id @default(uuid())
  slug       String   @unique
  title      String
  titleEn    String?
  content    String
  contentEn  String?
  coverImage String?
  category   String   @default("general")
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  title     String?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
}

model Comment {
  id        String    @id @default(uuid())
  page      String
  content   String
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  likes     Int       @default(0)
  createdAt DateTime  @default(now())
  likedBy   CommentLike[]
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  user      User     @relation(fields: [userId], references: [id])
  comment   Comment  @relation(fields: [commentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}
