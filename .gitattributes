# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env.example text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Config files
.gitattributes export-ignore
.gitignore export-ignore
.editorconfig export-ignore
.github/ export-ignore

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.mp3 binary
*.mp4 binary
*.webm binary
*.mov binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock files (generated, treat as binary to reduce diff noise)
package-lock.json binary
pnpm-lock.yaml binary

# Linguist overrides — mark generated/source files
pnpm-lock.yaml linguist-generated=true
package-lock.json linguist-generated=true
dist/ linguist-generated=true
